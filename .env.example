# --- Base de datos (Turso / libSQL) ---
# En LOCAL puedes omitir estas dos variables: la app usa un archivo SQLite
# (file:data/madrugo.db) automáticamente.
#
# En PRODUCCIÓN (Vercel) son obligatorias. Se obtienen con la CLI de Turso:
#   turso db create madrugo
#   turso db show madrugo --url            -> TURSO_DATABASE_URL
#   turso db tokens create madrugo         -> TURSO_AUTH_TOKEN
TURSO_DATABASE_URL=libsql://tu-base.turso.io
TURSO_AUTH_TOKEN=tu-token-de-turso

# --- Sesión ---
# Clave para firmar la cookie de sesión (HMAC). OBLIGATORIO en producción.
# Genera una con:  openssl rand -hex 32
SESSION_SECRET=cambia-esto-por-una-clave-larga-y-aleatoria
